{
  "name": "bestdori-webtextconverter",
  "version": "1.0.0",
  "private": true,
  "description": "Bestdori Web Text Converter backend migrated to Node.js",
  "bin": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "node --watch backend/server.js",
    "dev:frontend": "webpack --watch --mode development",
    "build": "webpack --mode production"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.8.0",
    "marked": "^13.0.3",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "npm-run-all": "^4.1.5",
    "sharp": "^0.34.5",
    "string-replace-loader": "^3.3.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
